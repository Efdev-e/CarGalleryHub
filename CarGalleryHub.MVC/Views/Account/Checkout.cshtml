@model CarGalleryHub.MVC.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Ödeme Adımı";
}

<form id="checkoutForm" asp-controller="Account" asp-action="Checkout" method="post">
    <div class="row g-4">
        <!-- Left: Cart Summary and Address Details -->
        <div class="col-lg-7">
            <!-- Cart Summary -->
            <div class="border border-secondary rounded-4 p-4 BG-ViolentBlack shadow-sm mb-4">
                <h4 class="QuickSand Pure-White mb-3">Sipariş Özeti</h4>
                @if (Model.Cart?.CartItems != null && Model.Cart.CartItems.Any())
                {
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var item in Model.Cart.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-secondary">
                                <div>
                                    <span class="Pure-White fw-bold">@item.ItemName</span>
                                    <span class="Pure-Gray small ms-2">x @item.Quantity</span>
                                </div>
                                <span class="badge bg-secondary">@((item.UnitPrice * item.Quantity).ToString("0.##")) ₺</span>
                            </div>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="Pure-White fw-bold">Genel Toplam:</span>
                        <h5 class="text-success mb-0 fw-bold">@((Model.Cart.TotalPrice).ToString("0.##")) ₺</h5>
                    </div>
                }
            </div>

            <!-- Address Info Form -->
            <div class="border border-secondary rounded-4 p-4 BG-ViolentBlack shadow-sm">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="QuickSand Pure-White mb-0">Teslimat Adresi</h4>
                    @if (Model.SavedAddresses != null && Model.SavedAddresses.Any())
                    {
                        <div style="max-width: 250px;">
                            <select id="savedAddressSelect" class="form-select bg-dark text-white border-secondary form-select-sm">
                                <option value="">-- Kayıtlı Adres Seçin --</option>
                                @foreach (var addr in Model.SavedAddresses)
                                {
                                    <option value="@addr.Id" 
                                            data-fullname="@addr.FullName"
                                            data-city="@addr.City"
                                            data-district="@addr.District"
                                            data-postalcode="@addr.PostalCode"
                                            data-fulladdress="@addr.FullAddress">
                                        @addr.FullName (@addr.City)
                                    </option>
                                }
                            </select>
                        </div>
                    }
                </div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label QuickSand Pure-White">Ad Soyad</label>
                        <input id="AddressFullName" class="form-control bg-dark text-white border-secondary" asp-for="AddressFullName" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label QuickSand Pure-White">Şehir</label>
                        <input id="AddressCity" class="form-control bg-dark text-white border-secondary" asp-for="AddressCity" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label QuickSand Pure-White">İlçe</label>
                        <input id="AddressDistrict" class="form-control bg-dark text-white border-secondary" asp-for="AddressDistrict" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label QuickSand Pure-White">Posta Kodu</label>
                        <input id="AddressPostalCode" class="form-control bg-dark text-white border-secondary" asp-for="AddressPostalCode" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label QuickSand Pure-White">Tam Adres</label>
                        <textarea id="FullAddress" class="form-control bg-dark text-white border-secondary" asp-for="FullAddress" rows="3" required></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Payment/Card Details -->
        <div class="col-lg-5">
            <div class="border border-secondary rounded-4 p-4 BG-ViolentBlack shadow-sm h-100 d-flex flex-column justify-content-between">
                <div>
                    <h4 class="QuickSand Pure-White mb-3">Ödeme Bilgileri</h4>
                    <p class="Pure-Gray small mb-4">Iyzico güvenli ödeme altyapısı ile kart bilgilerinizi girerek ödemenizi tamamlayın.</p>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label QuickSand Pure-White">Kart Sahibi Ad Soyad</label>
                            <input class="form-control bg-dark text-white border-secondary text-uppercase" asp-for="CardHolderName" required placeholder="JOHN DOE" />
                        </div>
                        <div class="col-12">
                            <label class="form-label QuickSand Pure-White">Kart Numarası</label>
                            <input id="cardNumber" class="form-control bg-dark text-white border-secondary" asp-for="CardNumber" required placeholder="0000 0000 0000 0000" maxlength="19" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label QuickSand Pure-White">Son Kullanma (Ay/Yıl)</label>
                            <div class="input-group">
                                <input class="form-control bg-dark text-white border-secondary text-center" asp-for="ExpiryMonth" required placeholder="AA" maxlength="2" />
                                <span class="input-group-text bg-secondary border-secondary text-white">/</span>
                                <input class="form-control bg-dark text-white border-secondary text-center" asp-for="ExpiryYear" required placeholder="YY" maxlength="2" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label QuickSand Pure-White">CVV</label>
                            <input class="form-control bg-dark text-white border-secondary text-center" asp-for="Cvv" required placeholder="000" maxlength="3" />
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-4 border-top border-secondary">
                    <button type="submit" class="btn btn-success w-100 py-3 fw-bold shadow-sm d-flex align-items-center justify-content-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-shield-lock" viewBox="0 0 16 16">
                            <path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .102-.025q.114-.033.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/>
                            <path d="M9.5 6.5a1.5 1.5 0 0 1-1 1.415V11a.5.5 0 0 1-1 0V7.915A1.5 1.5 0 1 1 9.5 6.5"/>
                        </svg>
                        Güvenli Ödeme Yap
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Auto fill Address when selected
            const addressSelect = document.getElementById("savedAddressSelect");
            if (addressSelect) {
                addressSelect.addEventListener("change", function () {
                    const selectedOpt = this.options[this.selectedIndex];
                    if (selectedOpt && selectedOpt.value !== "") {
                        document.getElementById("AddressFullName").value = selectedOpt.dataset.fullname || "";
                        document.getElementById("AddressCity").value = selectedOpt.dataset.city || "";
                        document.getElementById("AddressDistrict").value = selectedOpt.dataset.district || "";
                        document.getElementById("AddressPostalCode").value = selectedOpt.dataset.postalcode || "";
                        document.getElementById("FullAddress").value = selectedOpt.dataset.fulladdress || "";
                    }
                });
            }

            // Card Number Formatter (spaces every 4 digits)
            const cardInput = document.getElementById("cardNumber");
            if (cardInput) {
                cardInput.addEventListener("input", function (e) {
                    let value = e.target.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
                    let matches = value.match(/\d{4,16}/g);
                    let match = matches && matches[0] || '';
                    let parts = [];

                    for (let i = 0, len = match.length; i < len; i += 4) {
                        parts.push(match.substring(i, i + 4));
                    }

                    if (parts.length > 0) {
                        e.target.value = parts.join(' ');
                    } else {
                        e.target.value = value;
                    }
                });
            }
        });
    </script>
}
