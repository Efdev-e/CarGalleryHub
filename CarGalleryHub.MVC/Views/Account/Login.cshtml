@model CarGalleryHub.Application.DTOs.Auth.LoginRequestDto
@{
    ViewData["Title"] = "Giriş";
}

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="card-luxury w-100" style="max-width: 480px;">
        <h2 class="text-center mb-2 text-gold-gradient fw-bold" style="font-size: 1.8rem;">GİRİŞ YAP</h2>
        <p class="text-center text-muted-gray small mb-4" style="letter-spacing: 0.1em;">AGARTE DÜNYASINA ADIM ATIN</p>

        <form asp-controller="Account" asp-action="Login" method="post" class="d-flex flex-column gap-4">
            <div asp-validation-summary="ModelOnly" class="text-danger small text-center"></div>

            <div class="form-group">
                <label class="form-label text-gold mb-2 fw-semibold small" style="letter-spacing: 0.05em;" asp-for="Email">E-POSTA ADRESİ</label>
                <input required asp-for="Email" class="form-control form-control-luxury" type="email" placeholder="ornek@domain.com" value="Kingston@gmail.com" />
                <span class="text-danger small mt-1 d-block" asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label class="form-label text-gold mb-2 fw-semibold small" style="letter-spacing: 0.05em;" asp-for="Password">ŞİFRE</label>
                <input required asp-for="Password" class="form-control form-control-luxury" type="password" placeholder="••••••••" value="SuperGizliSifre" />
                <span class="text-danger small mt-1 d-block" asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="btn btn-gold w-100 py-3 mt-2 fw-bold">
                GİRİŞ YAP
            </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top border-gold-subtle">
            <p class="text-muted-gray small mb-0">
                Hesabınız yok mu? 
                <a asp-controller="Account" asp-action="Register" class="text-gold fw-bold ms-1 text-decoration-none">Kayıt Olun</a>
            </p>
        </div>
    </div>
</div>