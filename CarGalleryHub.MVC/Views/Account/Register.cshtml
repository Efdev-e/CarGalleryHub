@model CarGalleryHub.Application.DTOs.Auth.RegisterRequestDto
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="card-luxury w-100" style="max-width: 520px;">
        <h2 class="text-center mb-2 text-gold-gradient fw-bold" style="font-size: 1.8rem;">KAYIT OL</h2>
        <p class="text-center text-muted-gray small mb-4" style="letter-spacing: 0.1em;">AGARTE ÜYELİĞİNİZİ BAŞLATIN</p>

        <form asp-controller="Account" asp-action="Register" method="post" class="d-flex flex-column gap-3">
            <div asp-validation-summary="ModelOnly" class="text-danger small text-center"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-gold mb-1 fw-semibold small" style="letter-spacing: 0.05em;" asp-for="FirstName">AD</label>
                    <input required asp-for="FirstName" class="form-control form-control-luxury" type="text" placeholder="Ör. Can" />
                    <span class="text-danger small mt-1 d-block" asp-validation-for="FirstName"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-gold mb-1 fw-semibold small" style="letter-spacing: 0.05em;" asp-for="LastName">SOYAD</label>
                    <input required asp-for="LastName" class="form-control form-control-luxury" type="text" placeholder="Ör. Demir" />
                    <span class="text-danger small mt-1 d-block" asp-validation-for="LastName"></span>
                </div>
            </div>

            <div class="form-group mt-2">
                <label class="form-label text-gold mb-1 fw-semibold small" style="letter-spacing: 0.05em;" asp-for="Email">E-POSTA ADRESİ</label>
                <input required asp-for="Email" class="form-control form-control-luxury" type="email" placeholder="ornek@domain.com" />
                <span class="text-danger small mt-1 d-block" asp-validation-for="Email"></span>
            </div>

            <div class="form-group mt-2">
                <label class="form-label text-gold mb-1 fw-semibold small" style="letter-spacing: 0.05em;" asp-for="Password">ŞİFRE</label>
                <input required asp-for="Password" class="form-control form-control-luxury" type="password" placeholder="••••••••" />
                <span class="text-danger small mt-1 d-block" asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="btn btn-gold w-100 py-3 mt-3 fw-bold">
                KAYIT OL
            </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top border-gold-subtle">
            <p class="text-muted-gray small mb-0">
                Zaten bir hesabınız var mı? 
                <a asp-controller="Account" asp-action="Login" class="text-gold fw-bold ms-1 text-decoration-none">Giriş Yapın</a>
            </p>
        </div>
    </div>
</div>