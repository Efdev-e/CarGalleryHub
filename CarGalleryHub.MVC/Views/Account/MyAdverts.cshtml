@model CarGalleryHub.MVC.Models.DTOs.Advert.AdvertPageViewDto
@{
    ViewData["Title"] = "İlanlarım";
}

<div class="border border-secondary rounded-4 p-4 BG-ViolentBlack shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="QuickSand Pure-White mb-1">İlanlarım</h4>
            <p class="Pure-Gray small mb-0">Kendi paylaştığınız ilanları burada yönetebilirsiniz.</p>
        </div>
        <a asp-controller="Account" asp-action="CreateAdvert" class="btn btn-outline-light">Yeni İlan Ekle</a>
    </div>

    <form asp-controller="Account" asp-action="MyAdverts" method="get" class="mb-4">
        <div class="input-group">
            <input name="name" class="form-control bg-dark text-white border-secondary" placeholder="İlan adı ile ara" value="@Context.Request.Query["name"]" />
            <button type="submit" class="btn btn-outline-light">Ara</button>
        </div>
    </form>

    @if (Model.Dtos.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var advert in Model.Dtos)
            {
                <div class="col">
                    <div class="card h-100 border border-secondary rounded-3 overflow-hidden BG-Black">
                        <img src="@(string.IsNullOrWhiteSpace(advert.ImageUrl) ? "https://via.placeholder.com/600x400?text=Agarte" : advert.ImageUrl)" class="card-img-top" style="height: 220px; object-fit: cover;" />
                        <div class="card-body d-flex flex-column">
                            <h6 class="Pure-White mb-2">@advert.AdvertTitle</h6>
                            <p class="Pure-Gray small mb-3">@advert.Description</p>
                            <p class="Showcase-Gold Text-Bold mb-3">@advert.UnitPrice ₺</p>
                            <div class="d-flex gap-2 mt-auto">
                                <a asp-controller="Account" asp-action="EditAdvert" asp-route-id="@advert.Id" class="btn btn-outline-light btn-sm">Düzenle</a>
                                <form asp-controller="Account" asp-action="DeleteAdvert" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@advert.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Sil</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="border border-secondary rounded-3 p-4 text-center">
            <p class="Pure-Gray mb-0">Henüz paylaşmış olduğunuz ilan bulunmuyor.</p>
        </div>
    }

    <div class="d-flex justify-content-center align-items-center gap-2 mt-4">
        @if (Model.page > 1)
        {
            <a asp-action="MyAdverts" asp-route-page="@(Model.page - 1)" class="btn btn-outline-light">@(Model.page - 1)</a>
        }
        <a asp-action="MyAdverts" asp-route-page="@Model.page" class="btn btn-light">@Model.page</a>
        @if (Model.Dtos.Any() && Model.Dtos.Count >= 10)
        {
            <a asp-action="MyAdverts" asp-route-page="@(Model.page + 1)" class="btn btn-outline-light">@(Model.page + 1)</a>
        }
    </div>
</div>
