@model CarGalleryHub.MVC.Models.DTOs.Advert.AdvertCreateViewDto
@{
    ViewData["Title"] = "İlan Oluştur";
}

<div class="border border-secondary rounded-4 p-4 BG-ViolentBlack shadow-sm">
    <h4 class="QuickSand Pure-White mb-3">Yeni İlan Oluştur</h4>
    <form asp-controller="Account" asp-action="CreateAdvert" method="post">
        <div class="mb-3">
            <label class="form-label Pure-White">Başlık</label>
            <input asp-for="createAdvertDto.AdvertTitle" class="form-control bg-dark text-white border-secondary" />
        </div>
        <div class="mb-3">
            <label class="form-label Pure-White">Açıklama</label>
            <textarea asp-for="createAdvertDto.Description" class="form-control bg-dark text-white border-secondary" rows="4"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label Pure-White">Fiyat</label>
            <input asp-for="createAdvertDto.UnitPrice" class="form-control bg-dark text-white border-secondary" />
        </div>
        <div class="mb-3">
            <label class="form-label Pure-White">Görsel URL</label>
            <input asp-for="createAdvertDto.ImageUrl" class="form-control bg-dark text-white border-secondary" />
        </div>
        <div class="mb-3">
            <label class="form-label Pure-White">Araç</label>
            <select asp-for="createAdvertDto.CarId" class="form-select bg-dark text-white border-secondary">
                <option value="">Seçiniz</option>
                @foreach (var car in Model.Cars)
                {
                    <option value="@car.Id">@car.FullName</option>
                }
            </select>
        </div>
        <div class="form-check form-switch mb-3">
            <input asp-for="createAdvertDto.Warranty" class="form-check-input" />
            <label class="form-check-label Pure-White" asp-for="createAdvertDto.Warranty">Garanti var</label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-outline-light">Oluştur</button>
            <a asp-action="MyAdverts" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>
