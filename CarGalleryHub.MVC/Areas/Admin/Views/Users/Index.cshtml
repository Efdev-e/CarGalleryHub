@model CarGalleryHub.MVC.Models.DTOs.User.UserPageViewDto
@{
    ViewData["Title"] = "Kullanıcı Yönetimi - Agarte";
}

<div class="mb-5 text-center text-md-start">
    <span class="text-gold fw-bold mb-2 d-inline-block" style="letter-spacing: 0.3em; font-size: 0.85rem;">KONSOL &nbsp; MODÜLÜ</span>
    <h1 class="text-gold-gradient fw-bold mb-2" style="font-family: 'Cinzel', serif; font-size: 2.2rem;">ÜYE YÖNETİMİ</h1>
    <p class="text-muted-gray mb-0" style="font-weight: 300; font-size: 0.95rem;">Sistem üyelerini, yetki seviyelerini ve profil bilgilerini yönetin.</p>
</div>

<div class="table-responsive w-100 mx-auto">
    <table class="table align-middle">
        <thead>
            <tr>
                <th style="width: 80px;">#</th>
                <th>AD SOYAD</th>
                <th>E-POSTA</th>
                <th>TELEFON</th>
                <th style="width: 140px;">ROL</th>
                <th style="width: 180px;">KAYIT TARİHİ</th>
                <th style="width: 120px; text-align: center;">İŞLEMLER</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Users != null && Model.Users.Any())
            {
                foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td class="fw-semibold text-white">@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "-" : user.PhoneNumber)</td>
                        <td>
                            @if (user.Role == CarGalleryHub.Domain.Enum.UserRoles.Admin)
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 fw-bold" style="letter-spacing: 0.05em; border-radius: 4px;">ADMIN</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary text-white px-3 py-2 fw-bold" style="letter-spacing: 0.05em; border-radius: 4px;">CUSTOMER</span>
                            }
                        </td>
                        <td>@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td style="text-align: center;">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-gold py-1 px-3 fw-bold" style="font-size: 0.75rem;">DÜZENLE</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted-gray">Sistemde kayıtlı kullanıcı bulunmuyor.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
