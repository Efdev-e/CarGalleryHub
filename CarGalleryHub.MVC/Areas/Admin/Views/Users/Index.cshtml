@model CarGalleryHub.MVC.Models.DTOs.User.UserPageViewDto
@{
    ViewData["Title"] = "Users";
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="BG-Menu ToCenter w-75 me-3 ms-3">
    <div class="container">
        <div class="row g-3">
            <div class="col-12">
                <h3 class="text-white m-0">Kullanıcılar</h3>
            </div>
        </div>
    </div>
</div>

<br />
<hr style="color: white !important; border-color: white !important;" />
<br />

<div class="table-responsive w-75 mx-auto">
    <table class="table table-dark table-striped table-bordered align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Ad Soyad</th>
                <th>Email</th>
                <th>Telefon</th>
                <th>Rol</th>
                <th>Oluşturulma</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Users.Any())
            {
                foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td>@user.Role</td>
                        <td>@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">Veri yok</td>
                </tr>
            }
        </tbody>
    </table>
</div>
