@model CarGalleryHub.Application.DTOs.Advert.CreateAdvertDto
@{
    ViewData["Title"] = "Advert";
}
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form asp-controller="Adverts" asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="d-flex flex-column gap-4 border-1 border-black rounded-1">
        <div>
            <label class="form-label" asp-for="AdvertTitle">Başlık</label>

            <input asp-for="AdvertTitle" class="form-control" style="color: black !important;" type="text" placeholder="example@gmail.com" />

            <span class="text-danger d-block" asp-validation-for="AdvertTitle"></span>
        </div>

        <div>
            <label class="form-label" asp-for="Description">Açıklama</label>

            <textarea asp-for="Description" class="form-control" style="color: black !important;" placeholder="Açıklama Buraya"></textarea>

            <span class="text-danger d-block" asp-validation-for="Description"></span>
        </div>

        <div>
            <label class="form-label" asp-for="CarId">Araba Id'si</label>

            <input asp-for="CarId" class="form-control" style="color: black !important;" type="text" placeholder="1.2..3 vb" />

            <span class="text-danger d-block" asp-validation-for="CarId"></span>
        </div>

        <div>
            <label class="form-label" asp-for="ImageUrl">Resim Url'i</label>

            <input asp-for="ImageUrl" class="form-control" style="color: black !important;" type="text" placeholder="https://www.example.image" />

            <span class="text-danger d-block" asp-validation-for="ImageUrl"></span>
        </div>

        <div>
            <label class="form-label" asp-for="UnitPrice">Fiyat</label>

            <input asp-for="UnitPrice" class="form-control" style="color: black !important;" type="text" placeholder="10.000₺" />

            <span class="text-danger d-block" asp-validation-for="UnitPrice"></span>
        </div>

        <div>
            <label class="form-label" asp-for="Warranty">Sigortalı</label>

            <input asp-for="Warranty" class="form-check" style="color: black !important;" type="checkbox" />

            <span class="text-danger d-block" asp-validation-for="Warranty"></span>
        </div>

        <input asp-for="SellerId" type="hidden" />

        <input type="submit" value="Gönder" class="form-control" />
    </div>
</form>
