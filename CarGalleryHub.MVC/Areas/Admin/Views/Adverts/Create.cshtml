
@model CarGalleryHub.MVC.Models.DTOs.Advert.AdvertCreateViewDto
@{
    ViewData["Title"] = "Advert";
}
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form asp-controller="Adverts" asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="d-flex flex-column gap-4 border-1 border-black rounded-1">
        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="createAdvertDto.AdvertTitle">Başlık</label>

            <input required asp-for="createAdvertDto.AdvertTitle" class="form-control" style="color: black !important;" type="text" placeholder="ex" />

            <span class="text-danger d-block" asp-validation-for="createAdvertDto.AdvertTitle"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="createAdvertDto.Description">Açıklama</label>

            <textarea required asp-for="createAdvertDto.Description" class="form-control" style="color: black !important;" placeholder="Açıklama Buraya"></textarea>

            <span class="text-danger d-block" asp-validation-for="createAdvertDto.Description"></span>
        </div>

        <!-- CAR SEÇ-->
        <div>
            <label class="form-label" asp-for="createAdvertDto.CarId">Araba Listesi</label>
            <select required asp-for="createAdvertDto.CarId">
                <option value="">--- ARABA SEÇİNİZ ---</option>
                @foreach (var car in Model.Cars)
                {
                    <option value="@car.Id">@car.FullName</option>
                }
            </select>
        </div>

        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="createAdvertDto.ImageUrl">Resim Url'i</label>

            <input required asp-for="createAdvertDto.ImageUrl" class="form-control" style="color: black !important;" type="text" placeholder="https://www.example.image" />

            <span class="text-danger d-block" asp-validation-for="createAdvertDto.ImageUrl"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="createAdvertDto.UnitPrice">Fiyat</label>

            <input required asp-for="createAdvertDto.UnitPrice" class="form-control" style="color: black !important;" type="text" placeholder="10.000₺" />

            <span class="text-danger d-block" asp-validation-for="createAdvertDto.UnitPrice"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="createAdvertDto.Warranty">Sigortalı</label>

            <input required asp-for="createAdvertDto.Warranty" class="form-check" style="color: black !important;" type="checkbox" />

            <span class="text-danger d-block" asp-validation-for="createAdvertDto.Warranty"></span>
        </div>

        <input asp-for="createAdvertDto.SellerId" type="hidden" />

      <div class="row justify-content-center">
          <div class="col-6 d-flex">
                <input type="submit" value="Gönder" class="form-control w-auto " />
                <button type="button" onclick="history.back()" class="btn btn-secondary mt-2">Geri Dön</button>
          </div>
      </div>
    </div>
</form>














