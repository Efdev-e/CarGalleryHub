@model CarGalleryHub.MVC.Models.DTOs.AdvertViewDto
@{
    ViewData["Title"] = "Advert Update";
}

<form asp-controller="Adverts" asp-action="Update" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="d-flex flex-column gap-3 w-50">
        <div>
            <label class="form-label" style="color: white !important;">İlan Başlığı</label>
            <input asp-for="updateAdvert.AdvertTitle" class="form-control" style="color: black !important;" placeholder="Başlık" />
            <span asp-validation-for="updateAdvert.AdvertTitle" class="text-danger mb-3"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;" >Açıklama</label>
            <input asp-for="updateAdvert.Description" class="form-control" style="color: black !important;" placeholder="Açıklama" />
            <span asp-validation-for="updateAdvert.Description" class="text-danger mb-3"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;" >Fiyat</label>
            <input asp-for="updateAdvert.UnitPrice" class="form-control" style="color: black !important;" placeholder="örn: 10.000₺" />
            <span asp-validation-for="updateAdvert.UnitPrice" class="text-danger mb-3"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;" >Araba </label>
            <select class="form-control" asp-for="carModels">
                <option value="">-- Araba Seçin --</option>
                @if (Model.carModels != null)
                {
                    foreach (var info in Model.carModels)
                    {
                        <option value="@info.Id">@info.FullName</option>
                    }
                }
                <span asp-validation-for="updateAdvert.AdvertTitle" class="text-danger mb-3"></span>
            </select>
        </div>

        <div>
            <label class="form-label">Image Url</label>
            <input asp-for="updateAdvert.ImageUrl" class="form-control" style="color: black !important;" placeholder="örn: 10.000₺" />
            <span asp-validation-for="updateAdvert.ImageUrl" class="text-danger mb-3"></span>
        </div>

        <input type="submit" value="Gönder" class="form-control" />
    </div>
</form>

