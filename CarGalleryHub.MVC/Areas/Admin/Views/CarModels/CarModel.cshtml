
@model CarGalleryHub.MVC.Models.DTOs.CarModel.CarModelnspectView
@{
    ViewData["Title"] = "Car Model";
}
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="d-flex flex-column gap-4 border-1 border-black rounded-1">
        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="data.carModel.Series">Seri: @Model.data.carModel.Series</label>
            <span class="text-danger d-block" asp-validation-for="data.carModel.Series"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="data.carModel.Model">Model: @Model.data.carModel.Model</label>
            <span class="text-danger d-block" asp-validation-for="data.carModel.Model"></span>
        </div>

        <div>
            <label class="form-label" style="color: white !important;font-family:'Quicksand'; font-weight: 500" asp-for="data.carModel.ReleaseDate">Çıkış Tarihi: @Model.data.carModel.ReleaseDate</label>
            <span class="text-danger d-block" asp-validation-for="data.carModel.ReleaseDate"></span>
        </div>

        <div>
            <label class="form-label" asp-for="data.BrandName" style="color: white !important; font-family:'Quicksand'; font-weight: 500">Marka: @Model.data.BrandName</label>
        </div>

        <div class="border border-1 border-secondary p-2">
            <label class="form-check" style="color: white !important; font-family:'Quicksand'; font-weight: 500">Marka Modelleri</label>
            <ul class="list-group" style="max-height: 300px; overflow-y: auto;">
                @foreach (var dto in Model.data.Cars)
                {
                    <li class="list-group-item bg-dark text-white border-secondary">
                        @dto.FullName
                    </li>
                }
                @if (!Model.data.Cars.Any())
                {
                    <li class="list-group-item bg-dark text-white border-secondary">
                        Yok
                    </li>
                }
            </ul>
        </div>

      <div class="row justify-content-center">
          <div class="col-6 d-flex">
                <button type="button" onclick="history.back()" class="btn btn-secondary mt-2">Geri Dön</button>
          </div>
      </div>
    </div>
</form>














