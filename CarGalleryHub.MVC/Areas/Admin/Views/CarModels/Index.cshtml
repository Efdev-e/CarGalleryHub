@model CarGalleryHub.MVC.Models.DTOs.CarModel.CarModelPageView
@{
    ViewData["Title"] = "Car Models";
}

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<form class="BG-Menu ToCenter w-75 me-3 ms-3" asp-action="Index" asp-controller="CarModels" asp-area="Admin" method="get">
    <div class="container">
        <div class="row g-3">
            <div class="col-12">
                <label for="Name" class="form-label text-white FilterText">Arama Kutusu:</label>
                <div class="input-group">
                    <input type="text" class="form-control bg-secondary text-white border-0" name="Name" placeholder="Arat" />
                    <button type="submit" class="btn btn-success">Arat</button>
                </div>
            </div>  
            <div class="col-12 mt-2">
                <a asp-area="Admin" asp-controller="CarModels" asp-action="Create" role="button" class="btn btn-success">OLUŞTUR</a>
            </div>
        </div>
    </div>
</form>

<br><hr style="color: white !important; border-color: white !important;" />
<br />
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 w-100 py-4 mx-auto">
    @if (Model.Dtos.Any())
    {
        foreach (var advert in Model.Dtos)
        {
            <div class="col">
                <div class="card bg-dark border-1 border-white rounded-1 h-100">
                    <div class="card-body bg-dark d-flex flex-col flex-column justify-content-between">

                        <div>
                            <h5 class="card-title text-center text-white mb-3">@advert.FullName</h5>
                            <p class="card-text text-white text-center">-</p>
                            <p class="card-text text-white text-center">@advert.BrandName</p>
                            <p class="card-text Filter-Text text-center">@advert.ReleaseDate</p>
                        </div>

                        <div class="d-flex flex-column gap-2 mt-auto">
                            <a asp-action="CarModel" asp-controller="CarModels" asp-route-id="@advert.Id" class="btn btn-outline-success">İncele</a>
                            <a asp-action="AddCar" asp-controller="CarModels" asp-route-id="@advert.Id" class="btn btn-outline-primary">Araba Ekle/Değiştir</a>
                            <a asp-action="Update" asp-controller="CarModels" asp-route-id="@advert.Id" class="btn btn-outline-success">Değiştir</a>
                            <a asp-action="Delete" asp-controller="CarModels" asp-route-id="@advert.Id" class="btn btn-outline-danger">Sil</a>
                        </div>

                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-white">
            <p>Veri yok</p>
        </div>
    }
</div>
<div class="row w-100 h-50">
    <div class="col-12 d-flex justify-content-center align-items-center g-3">
        <button>
            @if (Model.page > 1)
            {
                <a asp-action="Index" asp-controller="CarModels" asp-route-page="@(Model.page - 1)" class="btn btn-outline-success">@(Model.page - 1)</a>
            }
            <a asp-action="Index" asp-controller="CarModels" asp-route-page="@Model.page" class="btn btn-success">@Model.page</a>
            @if (Model.Dtos.Any() && Model.Dtos.Count >= 10)
            {
                <a asp-action="Index" asp-controller="CarModels" asp-route-page="@(Model.page + 1)" class="btn btn-outline-success">@(Model.page + 1)</a>
            }
        </button>
    </div>
</div>