@model CarGalleryHub.MVC.Models.DTOs.Brand.BrandCarModelView
@{
    ViewData["Title"] = "Advert";
}


<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="d-flex flex-column gap-3 w-50">
    <div class="border border-1 border-secondary p-2">
        <label class="form-label" asp-for="BrandName" style="color: white !important; font-family:'Quicksand'; font-weight: 500">Marka ismi: @Model.BrandName</label>
        <span asp-validation-for="BrandName" class="text-danger mb-3"></span>
    </div>
    <br />
    <div class="border border-1 border-secondary p-2">
        <label class="form-check" style="color: white !important; font-family:'Quicksand'; font-weight: 500">Marka Modelleri</label>
        <ul class="list-group" style="max-height: 300px; overflow-y: auto;">
            @if (Model.Dtos is not null && Model.Dtos.Any())
            {
                foreach (var dto in Model.Dtos)
                {
                    <li class="list-group-item bg-dark text-white border-secondary">
                        @dto.FullName
                    </li>
                }
            }
            else
            {
                <li class="list-group-item bg-dark text-white border-secondary">
                    Veri Yok
                </li>
            }
        </ul>
    </div>

    <button type="button" onclick="history.back()" style="font-family:'Quicksand'; font-weight: 500" class="btn btn-secondary mt-2">Geri Dön</button>
</div>